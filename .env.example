# InterviewAce AI - Environment Variable Configuration

# Set your OpenAI API Key here for platform-wide server-side fallbacks.
# Note: Users can also input their API keys directly in the platform Settings panel.
VITE_OPENAI_API_KEY= your_openai_api_key_here

# Firebase client config used by Vite to initialize authentication.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# Optional measurement ID for Analytics if you use it.
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend API base URL. Use your deployed HTTPS backend for GitHub Pages builds.
# Local development example:
VITE_API_BASE_URL=http://localhost:5000/api
# Production example:
# VITE_API_BASE_URL=https://your-backend-domain.example.com/api

# Optional base URL used by Vite for GitHub Pages asset paths.
# Example for GitHub Pages repository deploy:
# VITE_BASE_URL=/mini-project/
